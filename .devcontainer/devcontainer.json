{
  "name": "IBM Bob Labs",
  "image": "mcr.microsoft.com/devcontainers/jekyll:2-bullseye",
  "postCreateCommand": "bundle install",
  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "Site (open /bob-labs/)",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "yzhang.markdown-all-in-one",
        "DavidAnson.vscode-markdownlint"
      ]
    }
  }
}
